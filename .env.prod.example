# PostgreSQL
POSTGRES_USER=monitoring
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=monitoring

# Prometheus — Network 1 (Physical Servers)
PROM_NET1_URL=http://your-server-ip:9091
PROM_NET1_LABEL=Physical Servers

# Prometheus — Network 2 (Hetzner)
PROM_NET2_URL=http://your-server-ip:9092
PROM_NET2_LABEL=Hetzner Bare-Metal

# Prometheus — Network 3
PROM_NET3_URL=http://your-server-ip:9093
PROM_NET3_LABEL=Third Network
