# Copy this to apps/dashboard/.env and fill in your values

# Postgres (used for alert history and config storage)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/monitoring

# Network 1 — Physical Servers
PROM_NET1_URL=https://prom-net1.yourdomain.com
PROM_NET1_USER=admin
PROM_NET1_PASS=yourpassword1
PROM_NET1_LABEL=Physical Servers

# Network 2 — Hetzner Bare-Metal
PROM_NET2_URL=https://prom-hetzner.yourdomain.com
PROM_NET2_USER=admin
PROM_NET2_PASS=yourpassword2
PROM_NET2_LABEL=Hetzner Bare-Metal

# Network 3 — Third Network
PROM_NET3_URL=https://prom-net3.yourdomain.com
PROM_NET3_USER=admin
PROM_NET3_PASS=yourpassword3
PROM_NET3_LABEL=Third Network
